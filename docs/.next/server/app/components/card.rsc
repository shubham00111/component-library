30:T4e6,/* Flowbite Card — standalone snippet */
:root{--fb-color-bg:#ffffff;--fb-color-surface:#f9fafb;--fb-color-text:#111827;--fb-color-text-secondary:#6b7280;--fb-color-border:#e5e7eb;--fb-border-radius:8px;--fb-border-width:1px;--fb-shadow:0 1px 2px rgba(0,0,0,0.05);--fb-shadow-md:0 4px 6px -1px rgba(0,0,0,0.1);--fb-font-size-sm:0.875rem;--fb-font-weight-medium:500}
.fb-card{background:var(--fb-color-bg);border:var(--fb-border-width) solid var(--fb-color-border);border-radius:var(--fb-border-radius);box-shadow:var(--fb-shadow);font-family:system-ui,sans-serif;overflow:hidden;transition:all 200ms ease-in-out}
.fb-card:hover{box-shadow:var(--fb-shadow-md)}
.fb-card__image{width:100%;height:180px;object-fit:cover;display:block}
.fb-card__body{padding:16px}
.fb-card__title{font-size:1rem;font-weight:var(--fb-font-weight-medium);color:var(--fb-color-text);margin:0 0 6px 0;line-height:1.4}
.fb-card__description{font-size:var(--fb-font-size-sm);color:var(--fb-color-text-secondary);margin:0;line-height:1.5}
.fb-card__content{padding:0 16px 16px;color:var(--fb-color-text)}
.fb-card__footer{padding:12px 16px;border-top:var(--fb-border-width) solid var(--fb-color-border);background:var(--fb-color-surface);display:flex;align-items:center;gap:8px}
