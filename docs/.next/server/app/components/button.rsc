28:T4d1,<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Neobrutalism Button</title>
  <link rel="stylesheet" href="neobrutalism.css" />
</head>
<body style="padding: 32px; font-family: system-ui, sans-serif;">

  <!-- Primary -->
  <button class="nb-button nb-button--primary nb-button--md" type="button">Primary</button>

  <!-- Secondary -->
  <button class="nb-button nb-button--secondary nb-button--md" type="button">Secondary</button>

  <!-- Destructive -->
  <button class="nb-button nb-button--destructive nb-button--md" type="button">Destructive</button>

  <!-- Ghost -->
  <button class="nb-button nb-button--ghost nb-button--md" type="button">Ghost</button>

  <!-- Outline -->
  <button class="nb-button nb-button--outline nb-button--md" type="button">Outline</button>

  <!-- Small -->
  <button class="nb-button nb-button--primary nb-button--sm" type="button">Small</button>

  <!-- Large -->
  <button class="nb-button nb-button--primary nb-button--lg" type="button">Large</button>

  <!-- Disabled -->
  <button class="nb-button nb-button--primary nb-button--md" type="button" disabled>Disabled</button>

</body>
</html>
29:T9de,/* Neobrutalism Button — standalone snippet (tokens inlined) */

:root {
  --nb-color-primary: #facc15;
  --nb-color-secondary: #a3e635;
  --nb-color-danger: #ef4444;
  --nb-color-bg: #ffffff;
  --nb-color-text: #000000;
  --nb-color-border: #000000;
  --nb-color-disabled-bg: #d1d5db;
  --nb-color-disabled-text: #6b7280;
  --nb-border-width-thick: 3px;
  --nb-border-radius: 2px;
  --nb-shadow: 4px 4px 0 #000000;
  --nb-shadow-hover: 6px 6px 0 #000000;
  --nb-shadow-active: 2px 2px 0 #000000;
  --nb-font-weight-bold: 800;
  --nb-font-size-sm: 0.8125rem;
  --nb-font-size-base: 0.9375rem;
  --nb-font-size-lg: 1.125rem;
}

.nb-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  cursor: pointer;
  font-weight: var(--nb-font-weight-bold);
  font-size: var(--nb-font-size-base);
  font-family: system-ui, sans-serif;
  border-radius: var(--nb-border-radius);
  border: var(--nb-border-width-thick) solid var(--nb-color-border);
  box-shadow: var(--nb-shadow);
  padding: 8px 16px;
  text-decoration: none;
  white-space: nowrap;
  user-select: none;
  background-color: var(--nb-color-primary);
  color: var(--nb-color-text);
}

.nb-button:hover:not(:disabled) {
  box-shadow: var(--nb-shadow-hover);
  transform: translate(-1px, -1px);
}

.nb-button:active:not(:disabled) {
  box-shadow: var(--nb-shadow-active);
  transform: translate(2px, 2px);
}

.nb-button:focus-visible {
  outline: 3px solid var(--nb-color-border);
  outline-offset: 3px;
}

.nb-button--primary { background-color: var(--nb-color-primary); color: var(--nb-color-text); }
.nb-button--secondary { background-color: var(--nb-color-secondary); color: var(--nb-color-text); }
.nb-button--destructive { background-color: var(--nb-color-danger); color: #fff; }
.nb-button--ghost { background-color: var(--nb-color-bg); box-shadow: none; border-color: transparent; }
.nb-button--ghost:hover:not(:disabled) { background-color: var(--nb-color-primary); box-shadow: var(--nb-shadow); border-color: var(--nb-color-border); }
.nb-button--outline { background-color: transparent; color: var(--nb-color-text); }

.nb-button--sm { font-size: var(--nb-font-size-sm); padding: 4px 8px; }
.nb-button--md { padding: 8px 16px; }
.nb-button--lg { font-size: var(--nb-font-size-lg); padding: 12px 24px; }

.nb-button:disabled {
  background-color: var(--nb-color-disabled-bg);
  color: var(--nb-color-disabled-text);
  border-color: var(--nb-color-disabled-text);
  box-shadow: none;
  cursor: not-allowed;
  opacity: 0.7;
}
